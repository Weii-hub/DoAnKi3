@model DoAnKi3.Models.LICH_HEN

@{
    ViewBag.Title = "Đăng Ký Đặt Lịch";
}

<link rel="stylesheet" href="~/css/pages/booking.css" />

<div class="booking-wrapper">
    <div class="booking-card">
        <h2 class="text-center booking-title">ĐĂNG KÝ ĐẶT LỊCH</h2>

        @using (Html.BeginForm("Create", "Booking", FormMethod.Post, new { @class = "booking-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="row">
                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Họ tên</label>
                    <input type="text" name="TenKH" class="booking-input" placeholder="Nhập họ tên của bạn..." required />
                </div>

                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Số điện thoại</label>
                    <input type="tel" name="SoDienThoai" class="booking-input" placeholder="Số điện thoại..." required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Email</label>
                    <input type="email" name="Email" class="booking-input" placeholder="Email..." required />
                </div>

                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Tên thú cưng</label>
                    <input type="text" name="TenPet" class="booking-input" placeholder="Nhập tên thú cưng (Chó, Mèo...)" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Dịch vụ</label>
                    @Html.DropDownList("MaDV", null, "Chọn dịch vụ", new { @class = "booking-input", required = "required" })
                    @Html.ValidationMessage("MaDV", "", new { @class = "text-danger small mt-1" })
                </div>

                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Bác sĩ</label>
                    @Html.DropDownList("MaNV", null, "Chọn bác sĩ", new { @class = "booking-input" })
                    @Html.ValidationMessageFor(m => m.MaNV, "", new { @class = "text-danger small mt-1" })
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3 d-flex flex-column">
                    <label class="form-group-label">Ngày</label>
                    @Html.TextBoxFor(m => m.NgayHen, "{0:yyyy-MM-dd}", new { @class = "booking-input", type = "date", required = "required" })
                    @Html.ValidationMessageFor(m => m.NgayHen, "", new { @class = "text-danger small mt-1" })
                </div>

                <div class="col-md-6 mb-4 d-flex flex-column">
                    <label class="form-group-label">Giờ</label>
                    @Html.TextBoxFor(m => m.GioHen, new { @class = "booking-input", type = "time", required = "required" })
                    @Html.ValidationMessageFor(m => m.GioHen, "", new { @class = "text-danger small mt-1" })
                </div>
            </div>

            <div class="text-center mt-3">
                <button type="submit" class="btn-submit-booking">
                    ĐẶT LỊCH NGAY <span class="arrow-icon">➔</span>
                </button>
            </div>
        }
    </div>
</div>