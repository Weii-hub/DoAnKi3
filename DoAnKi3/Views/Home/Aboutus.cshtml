                    <div class="team-card__name">Đinh Nguyễn Minh Hiếu</div>
                    <div class="team-card__role">Bác sĩ thú y trưởng</div>
                    <p class="team-card__bio">10 năm kinh nghiệm, chuyên gia về thú y nội khoa và phẫu thuật nhỏ.</p>
                </div>
            </div>
            <div class="team-card">
                <div class="team-card__photo-placeholder">👩‍💼</div>
                <div class="team-card__body">
                    <div class="team-card__name">Đào Tuấn Phúc</div>
                    <div class="team-card__role">Giám đốc vận hành</div>
                    <p class="team-card__bio">Đảm bảo mọi quy trình vận hành suôn sẻ và trải nghiệm khách hàng hoàn hảo.</p>
                </div>
            </div>
            <div class="team-card">
                <div class="team-card__photo-placeholder">🧴</div>
                <div class="team-card__body">
                    <div class="team-card__name">Trần Vũ Nhật Nam</div>
                    <div class="team-card__role">Chuyên gia Grooming</div>
                    <p class="team-card__bio">Chứng chỉ quốc tế, đã chăm sóc hơn 3.000 bé chó mèo từ nhiều giống khác nhau.</p>
                </div>
            </div>
            <div class="team-card">
                <div class="team-card__photo-placeholder">✂️</div>
                <div class="team-card__body">
                    <div class="team-card__name">Bình</div>
                    <div class="team-card__role">Chuyên gia cắt tỉa</div>
                    <p class="team-card__bio">Chuyên gia cắt tỉa.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════
     CTA BANNER
════════════════════════════════════════════════ -->
<section class="about-cta">
    <div class="container">
        <h2 class="about-cta__heading">Bắt đầu hành trình<br>cùng PetCare hôm nay</h2>
        <p class="about-cta__sub">
            Đặt lịch ngay để bé yêu của bạn được trải nghiệm dịch vụ chăm sóc tốt nhất.
        </p>
        <a href="@Url.Action("Create","Booking")" class="btn-white">
            Đặt lịch ngay
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
        </a>
    </div>
</section>

@section Scripts {
    <script>
/* Animated counter – fires when element enters viewport */
(function () {
    const counters = document.querySelectorAll('.js-count');
    if (!counters.length) return;

    // Hỗ trợ prefers-reduced-motion để tối ưu khả năng tiếp cận (A11y)
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const animateCount = (el: HTMLElement) => {
        // Phòng thủ null-safety bằng toán tử logic ||
        const targetAttr = el.dataset.target || "0";
        const suffix = el.dataset.suffix || "";
        const target = parseInt(targetAttr, 10);

        if (prefersReduced) {
            el.textContent = target.toLocaleString('vi-VN') + suffix;
            return;
        }

        const duration = 1600;
        const start = performance.now();

       
        const step = (now:number) => {
            const progress = Math.min((now - start) / duration, 1);
            const ease = 1 - Math.pow(1 - progress, 3); // hiệu ứng ease-out-cubic

            el.textContent = Math.floor(ease * target).toLocaleString('vi-VN') + suffix;

            if (progress < 1) {
                requestAnimationFrame(step);
            }
        };
        requestAnimationFrame(step);
    };

    // Tạo bộ quan sát IntersectionObserver
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
            if (e.isIntersecting) {
                // Sửa tại đây: Sử dụng kỹ thuật ép kiểu (Type Assertion) của TypeScript
                const targetElement = e.target as HTMLElement;

                if (targetElement) {
                    animateCount(targetElement); // Không còn bị báo đỏ nữa!
                    observer.unobserve(targetElement);
                }
            }
        });
    }, { threshold: 0.4 });

    // Đăng ký toàn bộ các thẻ đếm số vào bộ quan sát
    counters.forEach((el) => {
        if (el) observer.observe(el);
    });
})();
    </script>
}
