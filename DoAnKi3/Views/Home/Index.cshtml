
@{
    ViewBag.Title = "Trang chủ";
}

<section class="pc-hero">

    <div class="pc-hero-bg">

        <div class="hero-blob-1"></div>
        <div class="hero-blob-2"></div>

    </div>

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <div class="pc-hero-content">

                    <div class="hero-eyebrow">

                        <i class="fa-solid fa-paw"></i>

                        PetCare Premium

                    </div>

                    <h1 class="hero-headline">

                        Chăm sóc thú cưng

                        <span class="highlight">
                            với cả trái tim
                        </span>

                    </h1>

                    <p class="hero-desc">

                        Dịch vụ Grooming, Spa, khám sức khỏe
                        và chăm sóc thú cưng chuyên nghiệp.

                    </p>

                    <div class="hero-cta">

                        <a href="/Booking/Create"
                           class="btn btn-primary btn-lg">

                            Đặt lịch ngay

                        </a>
                    </div>

                    <div class="hero-stats">

                        <div class="hero-stat-item">

                            <span class="stat-number">
                                500+
                            </span>

                            <span class="stat-label">
                                Khách hàng
                            </span>

                        </div>

                        <div class="hero-stat-item">

                            <span class="stat-number">
                                1000+
                            </span>

                            <span class="stat-label">
                                Thú cưng
                            </span>

                        </div>

                        <div class="hero-stat-item">

                            <span class="stat-number">
                                4.9★
                            </span>

                            <span class="stat-label">
                                Đánh giá
                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-6">

                <div class="hero-image-wrap">

                    <img src="~/css/images/cat1.png"
                         class="hero-img-main"
                         alt="PetCare" />

                    <div class="hero-floating-card card-top">

                        <div class="fc-icon">
                            <i class="fa-solid fa-heart"></i>
                        </div>

                        <div class="fc-text">

                            <strong>Yêu thương</strong>

                            <span>Chăm sóc tận tâm</span>

                        </div>

                    </div>

                    <div class="hero-floating-card card-bottom">

                        <div class="fc-icon">
                            <i class="fa-solid fa-shield-dog"></i>
                        </div>

                        <div class="fc-text">

                            <strong>An toàn</strong>

                            <span>Dịch vụ chuyên nghiệp</span>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>
