
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewBag.Title - PetCare</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/base/tokens.css" />
    <link rel="stylesheet" href="~/css/base/reset.css" />
    <link rel="stylesheet" href="~/css/base/utilities.css" />
    <link rel="stylesheet" href="~/css/layout/navbar.css" />
    <link rel="stylesheet" href="~/css/layout/footer.css" />
    <link rel="stylesheet" href="~/css/pages/home.css" />
    <link rel="stylesheet" href="~/css/pages/pet.css" />
    <link rel="stylesheet" href="~/css/pages/booking.css" />
    <link rel="stylesheet" href="~/css/pages/cart.css" />
    <link rel="stylesheet" href="~/css/pages/account.css" />
    <link rel="stylesheet" href="~/css/pages/about.css" />
    <link rel="stylesheet" href="~/css/pages/dvu.css" />

    @RenderSection("Styles", required: false)
</head>

<body>


    <nav class="navbar navbar-expand-lg pc-navbar sticky-top">

        <div class="container">

            <a class="navbar-brand fw-bold" href="@Url.Action("Index","Home")">

                <i class="fa-solid fa-paw"></i>

                PetCare

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMain">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbarMain">

                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Index","Home")">
                            Trang chủ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("dv","Dichvu")">
                            Dịch vụ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Create","Booking")">
                            Đặt lịch
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("shop","Product")">
                            Shop
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("LienHe","Dichvu")">
                            Liên hệ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Aboutus","Home")">
                            About us
                        </a>
                    </li>

                </ul>

                <div class="d-flex gap-2 align-items-center">
                    @if (Session["Username"] == null)
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary">
                            Đăng nhập
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-primary">
                            Đăng ký
                        </a>
                    }
                    else
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-regular fa-user me-1"></i>
                                @(Session["TenNguoiDung"] ?? Session["Username"])
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="min-width: 240px;">

                                @if (Session["VaiTro"]?.ToString() == "Admin")
                                {
                                    <li class="dropdown-header text-danger fw-bold text-uppercase small"><i class="fa-solid fa-user-shield me-1"></i> Quản trị viên</li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("EditProfile", "Account")">
                                            <i class="fa-solid fa-user-gear me-2 text-secondary"></i>Sửa thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("RevenueReport", "Admin")">
                                            <i class="fa-solid fa-chart-line me-2 text-secondary"></i>Xem doanh thu
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ManageEmployees", "Admin")">
                                            <i class="fa-solid fa-users-gear me-2 text-secondary"></i>Quản lý nhân sự
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ManageCategories", "Admin")">
                                            <i class="fa-solid fa-boxes-stacked me-2 text-secondary"></i>Quản lý danh mục
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ViewLogs", "Admin")">
                                            <i class="fa-solid fa-clipboard-list me-2 text-secondary"></i>Lưu log hoạt động
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("SystemConfig", "Admin")">
                                            <i class="fa-solid fa-sliders me-2 text-secondary"></i>Cấu hình hệ thống
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("EmployeePerformance", "Admin")">
                                            <i class="fa-solid fa-id-card-clip me-2 text-secondary"></i>Hiệu suất nhân viên
                                        </a>
                                    </li>
                                }

              
                                else if (Session["VaiTro"]?.ToString() == "BacSi")
                                {
                                    <li class="dropdown-header text-primary fw-bold text-uppercase small"><i class="fa-solid fa-user-doctor me-1"></i> Bác sĩ chuyên khoa</li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("EditProfile", "Account")">
                                            <i class="fa-solid fa-user-gear me-2 text-secondary"></i>Sửa thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Index", "AppointmentStaff")">
                                            <i class="fa-solid fa-clipboard-check me-2 text-secondary"></i>Tiếp nhận lịch hẹn
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("DoctorSchedule", "AppointmentStaff")">
                                            <i class="fa-solid fa-calendar-check me-2 text-secondary"></i>Quản lý lịch hẹn khám
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("MedicalRecords", "AppointmentStaff")">
                                            <i class="fa-solid fa-notes-medical me-2 text-secondary"></i>Quản lý hồ sơ bệnh án
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("UpdateStatus", "AppointmentStaff")">
                                            <i class="fa-solid fa-arrow-rotate-left me-2 text-secondary"></i>Cập nhật trạng thái lịch
                                        </a>
                                    </li>

                                }

                
                                else if (Session["VaiTro"]?.ToString() == "NhanVien")
                                {
                                    <li class="dropdown-header text-warning fw-bold text-uppercase small"><i class="fa-solid fa-user-tie me-1"></i> Nhân viên vận hành</li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("EditProfile", "Account")">
                                            <i class="fa-solid fa-user-gear me-2 text-secondary"></i>Sửa thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ProcessOrders", "StoreStaff")">
                                            <i class="fa-solid fa-truck-ramp-box me-2 text-secondary"></i>Tiếp nhận & Đóng gói đơn
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Inventory", "StoreStaff")">
                                            <i class="fa-solid fa-warehouse me-2 text-secondary"></i>Quản lý hàng tồn kho
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ExportRequest", "StoreStaff")">
                                            <i class="fa-solid fa-file-invoice me-2 text-secondary"></i>Tạo yêu cầu xuất sản phẩm
                                        </a>
                                    </li>
                                }

                       
                                else
                                {
                                    <li class="dropdown-header text-success fw-bold text-uppercase small"><i class="fa-solid fa-crown me-1"></i> Khách hàng thành viên</li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Create", "Booking")">
                                            <i class="fa-solid fa-calendar-plus me-2 text-secondary"></i>Đặt lịch hẹn dịch vụ
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("RoomBooking", "Booking")">
                                            <i class="fa-solid fa-hotel me-2 text-secondary"></i>Đặt phòng lưu trú thú cưng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Shop", "Product")">
                                            <i class="fa-solid fa-bag-shopping me-2 text-secondary"></i>Mua sắm sản phẩm
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Index", "Pet")">
                                            <i class="fa-solid fa-paw me-2 text-secondary"></i>Quản lý thú cưng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("BookingHistory", "Account")">
                                            <i class="fa-solid fa-clock-rotate-left me-2 text-secondary"></i>Xem lịch sử đặt lịch
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("MedicalHistory", "Account")">
                                            <i class="fa-solid fa-heart-pulse me-2 text-secondary"></i>Theo dõi bệnh án
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("SubscribedPackages", "Account")">
                                            <i class="fa-solid fa-cubes me-2 text-secondary"></i>Gói dịch vụ định kỳ
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("EditProfile", "Account")">
                                            <i class="fa-solid fa-user-gear me-2 text-secondary"></i>Sửa thông tin cá nhân
                                        </a>
                                    </li>
                                }

                                <li><hr class="dropdown-divider"></li>

                          
                                <li>
                                    <a class="dropdown-item text-danger fw-bold" href="@Url.Action("Logout", "Account")">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>

            </div>

        </div>

    </nav>



    <main>

        @RenderBody()

    </main>
    <footer class="site-footer">

  
        <div class="footer-newsletter">
            <div class="inner">
                <div class="newsletter-copy">
                    <h3>Nhận tips chăm sóc thú cưng 🐾</h3>
                    <p>Mẹo hữu ích, ưu đãi đặc biệt gửi thẳng đến hộp thư của bạn.</p>
                </div>
                <div class="newsletter-form">
                    <input type="email" placeholder="Email của bạn..." aria-label="Email đăng ký nhận tin" />
                    <button type="button">Đăng ký</button>
                </div>
            </div>
        </div>


        <div class="footer-body">


            <div class="footer-col footer-brand">
                <a href="/" class="brand-name">
                    <span class="paw-icon">🐾</span>
                    PetCare
                </a>
                <p class="tagline">
                    Chăm sóc thú cưng bằng cả trái tim —<br />
                    bởi vì chúng xứng đáng được yêu thương nhất.
                </p>

                <div class="hours-badge">
                    <span class="hours-dot"></span>
                    Mở cửa hôm nay · 08:00 – 20:00
                </div>

                <div class="social-row" style="margin-top: 20px;">
                    <a href="#" class="social-btn" aria-label="Facebook">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                        </svg>
                    </a>
                    <a href="#" class="social-btn" aria-label="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                        </svg>
                    </a>
                    <a href="#" class="social-btn" aria-label="TikTok">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z" />
                        </svg>
                    </a>
                    <a href="#" class="social-btn" aria-label="YouTube">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" />
                            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#1C1712" />
                        </svg>
                    </a>
                </div>
            </div>

  
            <div class="footer-col footer-contact">
                <h4>Liên hệ</h4>

                <div class="contact-item">
                    <span class="icon">📍</span>
                    <span>123 Nguyễn Văn Linh,<br />Quận 7, TP. Hồ Chí Minh</span>
                </div>

                <div class="contact-item">
                    <span class="icon">📞</span>
                    <a href="tel:0123456789">0123 456 789</a>
                </div>

                <div class="contact-item">
                    <span class="icon">✉️</span>
                    <a href="mailto:petcare@gmail.com">petcare@gmail.com</a>
                </div>

                <div class="contact-item">
                    <span class="icon">🕐</span>
                    <span>Thứ 2 – Chủ nhật<br />08:00 – 20:00</span>
                </div>
            </div>

        </div>


        <div class="footer-bottom">
            <div class="inner">
                <p class="copy">
                    &copy; @DateTime.Now.Year <span>PetCare</span>. Tất cả quyền được bảo lưu.
                </p>
                <nav class="legal-links" aria-label="Legal links">
                    <a href="/chinh-sach-bao-mat">Chính sách bảo mật</a>
                    <a href="/dieu-khoan">Điều khoản sử dụng</a>
                </nav>
            </div>
        </div>

    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
