
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewBag.Title - PetCare</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/base/tokens.css" />
    <link rel="stylesheet" href="~/css/base/reset.css" />
    <link rel="stylesheet" href="~/css/base/utilities.css" />
    <link rel="stylesheet" href="~/css/layout/navbar.css" />
    <link rel="stylesheet" href="~/css/layout/footer.css" />
    <link rel="stylesheet" href="~/css/pages/home.css" />
    <link rel="stylesheet" href="~/css/pages/pet.css" />
    <link rel="stylesheet" href="~/css/pages/booking.css" />
    <link rel="stylesheet" href="~/css/pages/cart.css" />
    <link rel="stylesheet" href="~/css/pages/account.css" />
    <link rel="stylesheet" href="~/css/pages/about.css" />

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg pc-navbar sticky-top">

        <div class="container">

            <a class="navbar-brand fw-bold" href="@Url.Action("Index","Home")">

                <i class="fa-solid fa-paw"></i>

                PetCare

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMain">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbarMain">

                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Index","Home")">
                            Trang chủ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("dv","Dichvu")">
                            Dịch vụ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Create","Booking")">
                            Đặt lịch
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("shop","Product")">
                            Shop
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Contact","Home")">
                            Liên hệ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="@Url.Action("Aboutus","Home")">
                            About us
                        </a>
                    </li>

                </ul>

                <div class="d-flex gap-2 align-items-center">
                    @if (Session["Username"] == null)
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary">
                            Đăng nhập
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-primary">
                            Đăng ký
                        </a>
                    }
                    else
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-regular fa-user me-1"></i>
                                @(Session["TenNguoiDung"] ?? Session["Username"])
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (Session["VaiTro"]?.ToString() != "KhachHang")
                                {
                                    // Nếu là Admin, Bác sĩ, Nhân viên thì hiện thêm nút vào trang quản lý
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Index", "Home")">
                                            <i class="fa-solid fa-gauge me-2"></i>Trang quản trị
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-menu-divider"></li>
                                }
                                <li>
                                    <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>

            </div>

        </div>

    </nav>

    <!-- BODY -->

    <main>

        @RenderBody()

    </main>
    <footer class="pc-footer">

        <div class="container py-5">

            <div class="row">

                <div class="col-lg-4">

                    <h4>PetCare</h4>

                    <p>
                        Chăm sóc thú cưng bằng cả trái tim.
                    </p>

                </div>

                <div class="col-lg-4">

                    <h5>Dịch vụ</h5>

                    <ul class="list-unstyled">

                        <li>Grooming</li>
                        <li>Spa</li>
                        <li>Khách sạn thú cưng</li>

                    </ul>

                </div>

                <div class="col-lg-4">

                    <h5>Liên hệ</h5>

                    <p>Email: petcare@gmail.com</p>

                    <p>Hotline: 0123 456 789</p>

                </div>

            </div>

        </div>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
