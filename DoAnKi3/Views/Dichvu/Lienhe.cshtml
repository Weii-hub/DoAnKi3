@model DoAnKi3.Models.LIEN_HE
@{
    ViewBag.Title = "Liên Hệ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/LienHe.css" />
<div class="contact-page">
    <div class="container">
        <div class="contact-page-header">
            <span class="label">Liên hệ với chúng tôi</span>
            <h1>Chúng tôi luôn lắng nghe 🐾</h1>
            <p>Có câu hỏi về dịch vụ hoặc cần tư vấn cho thú cưng? Điền vào biểu mẫu và chúng tôi sẽ phản hồi trong vòng 24 giờ.</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-petcare success">
                <span>✅</span> @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Count > 0)
        {
            <div class="alert-petcare error">
                <span>⚠️</span> Vui lòng kiểm tra lại thông tin bên dưới.
            </div>
        }


        <div class="contact-grid">


            <div class="contact-info-panel">

                <div class="info-card">
                    <div class="info-icon">📍</div>
                    <div class="info-text">
                        <h4>Địa chỉ</h4>
                        <p>123 Nguyễn Văn Linh,<br />Quận 7, TP. Hồ Chí Minh</p>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">📞</div>
                    <div class="info-text">
                        <h4>Điện thoại</h4>
                        <a href="tel:0123456789">0123 456 789</a>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">✉️</div>
                    <div class="info-text">
                        <h4>Email</h4>
                        <a href="mailto:petcare@gmail.com">petcare@gmail.com</a>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">🕐</div>
                    <div class="info-text">
                        <h4>Giờ mở cửa</h4>
                        <p>Thứ 2 - Chủ nhật<br />08:00 - 20:00</p>
                    </div>
                </div>

                <div class="map-card">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.954344838491!2d106.69115317583681!3d10.738002459898074!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x317528b2747a81a3%3A0x334c77d01ecfb868!2zMTIzIMSQxrDhu51uZyBOZ3V54buFbiBWxINuIExpbmgsIFTDom4gUGhvbmcsIFF14bqtbiA3LCBI4buTIENow0gTWluaA!5e0!3m2!1svi!2s!4v1710000000000!5m2!1svi!2s"
                            width="100%"
                            height="250"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Vị trí PetCare">
                    </iframe>
                </div>

            </div>

            <div class="contact-form-card">
                <h2>Gửi tin nhắn cho chúng tôi</h2>
                <p class="form-subtitle">Chúng tôi sẽ phản hồi trong vòng 24 giờ làm việc.</p>

                @using (Html.BeginForm("GuiLienHe", "LienHe", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-row">
                        <div class="form-group">
                            <label>Họ và tên <span class="required">*</span></label>
                            @Html.TextBoxFor(m => m.HoTen, new
                            {
                                @class = "form-control-pc" + (ViewData.ModelState["HoTen"]?.Errors.Count > 0 ? " input-error" : ""),
                                placeholder = "Nguyễn Văn A",
                                maxlength = "100"
                            })
                            @if (ViewData.ModelState["HoTen"]?.Errors.Count > 0)
                            {
                                <span class="field-error">@ViewData.ModelState["HoTen"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label>Email <span class="required">*</span></label>
                            @Html.TextBoxFor(m => m.Email, new
                            {
                                @class = "form-control-pc" + (ViewData.ModelState["Email"]?.Errors.Count > 0 ? " input-error" : ""),
                                placeholder = "email@example.com",
                                type = "email"
                            })
                            @if (ViewData.ModelState["Email"]?.Errors.Count > 0)
                            {
                                <span class="field-error">@ViewData.ModelState["Email"].Errors[0].ErrorMessage</span>
                            }
                        </div>
                    </div>

         
                    <div class="form-group">
                        <label>Số điện thoại</label>
                        @Html.TextBoxFor(m => m.SoDienThoai, new
                        {
                            @class = "form-control-pc",
                            placeholder = "0123 456 789",
                            type = "tel",
                            maxlength = "15"
                        })
                    </div>

              
                    <div class="form-group">
                        <label>Tiêu đề <span class="required">*</span></label>
                        @Html.TextBoxFor(m => m.TieuDe, new
                        {
                            @class = "form-control-pc" + (ViewData.ModelState["TieuDe"]?.Errors.Count > 0 ? " input-error" : ""),
                            placeholder = "Tôi muốn hỏi về dịch vụ Grooming...",
                            maxlength = "200"
                        })
                        @if (ViewData.ModelState["TieuDe"]?.Errors.Count > 0)
                        {
                            <span class="field-error">@ViewData.ModelState["TieuDe"].Errors[0].ErrorMessage</span>
                        }
                    </div>

                    <div class="form-group">
                        <label>Nội dung <span class="required">*</span></label>
                        @Html.TextAreaFor(m => m.NoiDung, 6, 0, new
                        {
                            @class = "form-control-pc" + (ViewData.ModelState["NoiDung"]?.Errors.Count > 0 ? " input-error" : ""),
                            placeholder = "Mô tả chi tiết câu hỏi hoặc vấn đề bạn cần hỗ trợ...",
                            maxlength = "2000",
                            id = "noiDungTextarea"
                        })
                        <div class="char-counter">
                            <span id="charCount">0</span>/2000 ký tự
                        </div>
                        @if (ViewData.ModelState["NoiDung"]?.Errors.Count > 0)
                        {
                            <span class="field-error">@ViewData.ModelState["NoiDung"].Errors[0].ErrorMessage</span>
                        }
                    </div>

                    <button type="submit" class="btn-submit-pc">
                        ✉️ Gửi tin nhắn
                    </button>
                }
            </div>

        </div>
    </div>
</div>


<script>
    (function () {
        var textarea = document.getElementById('noiDungTextarea');
        var counter  = document.getElementById('charCount');
        if (!textarea || !counter) return;

        var ta  = /** @@type {HTMLTextAreaElement} */ (textarea);
        var cnt = /** @@type {HTMLElement} */ (counter);

        function update() {
            var textarea = (typeof ta !== 'undefined') ? ta : document.querySelector('textarea') || document.getElementById('ta');
            var counter = (typeof cnt !== 'undefined') ? cnt : document.getElementById('cnt') || document.querySelector('#cnt');
            if (!textarea || !counter) return;
            counter.textContent = String(textarea.value.length);
        }

        ta.addEventListener('input', update);
        update();
    })();
</script>