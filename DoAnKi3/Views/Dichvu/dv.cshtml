@{
    ViewBag.Title = "Dịch vụ";
}

<section class="pc-section pc-services-page">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="services-title">Dịch Vụ</h1>
            <p class="services-subtitle">Địa Điểm Chăm Sóc Thú Cưng Tiêu Chuẩn Quốc Tế Tại TP.HCM</p>
            <div class="title-divider"></div>
        </div>

        <div class="services-grid">

            <a href="@Url.Action("Detail", "Dichvu", new { id = "cap-cuu" })" class="service-card">
                <div class="card-img-wrapper">
                    <img src="~/css/images/dv1.png" alt="Cấp cứu 24/7" class="service-img" />
                    <div class="card-overlay"></div>
                </div>
                <div class="card-content">
                    <h3 class="service-name">Cấp cứu 24/24</h3>
                </div>
            </a>

            <a href="@Url.Action("Detail", "Dichvu", new { id = "triet-san" })" class="service-card">
                <div class="card-img-wrapper">
                    <img src="~/css/images/dv2.png" alt="Triệt sản chó mèo" class="service-img" />
                    <div class="card-overlay"></div>
                </div>
                <div class="card-content">
                    <h3 class="service-name">Triệt sản chó và mèo</h3>
                </div>
            </a>

            <a href="@Url.Action("Detail", "Dichvu", new { id = "kham-benh" })" class="service-card">
                <div class="card-img-wrapper">
                    <img src="~/css/images/dv3.png" alt="Khám và điều trị bệnh" class="service-img" />
                    <div class="card-overlay"></div>
                </div>
                <div class="card-content">
                    <h3 class="service-name">Khám & Điều trị bệnh</h3>
                </div>
