                </div>
                <div class="card-content">
                    <h3 class="service-name">Phẫu thuật</h3>
                </div>
            </a>

            <a href="@Url.Action("Detail", "Dichvu", new { id = "chan-doan" })" class="service-card">
                <div class="card-img-wrapper">
                    <img src="~/css/images/dv5.png" alt="Chẩn đoán và xét nghiệm" class="service-img" />
                    <div class="card-overlay"></div>
                </div>
                <div class="card-content">
                    <h3 class="service-name">Chẩn đoán & Xét nghiệm</h3>
